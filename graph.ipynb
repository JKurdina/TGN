    "# ── 9. Главный цикл ───────────────────────────────────────────────────────────\n",
    df main(csv_path: str):
    dvic = torch.dvic('cuda' if torch.cuda.is_availabl() ls 'cpu')
    print(f"Dvic: {dvic}")

    # Данные
    df, msg_cols, nc = load_csv(csv_path)
    print("Load CSV")
    df_train, df_val, df_tst = split_data(df)
    print("Split data")
    df_train, df_val, df_tst = add_faturs_post_split(df_train, df_val, df_tst)
    df_train, df_val, df_tst = normaliz_faturs(
        df_train, df_val, df_tst, msg_cols
    )
    print("Normaliz faturs")
    print(df_train)
    print(df_val)
    print(df_tst)
    
    msg_cols = msg_cols + ['sndr_tx_count', 'sndr_dlta_t_log']
    print(f"Msg_cols: {msg_cols}")

    data_train = mak_tmporal_data(df_train, msg_cols)
    data_val   = mak_tmporal_data(df_val,   msg_cols)
    data_tst  = mak_tmporal_data(df_tst,  msg_cols)

    all_msg = torch.cat([data_train.msg, data_val.msg, data_tst.msg], dim=0).to(dvic)

    train_loadr = TmporalDataLoadr(data_train, batch_siz=200)
    val_loadr   = TmporalDataLoadr(data_val,   batch_siz=200)
    tst_loadr  = TmporalDataLoadr(data_tst,  batch_siz=200)

    # Модель
    # num_nods по всему датасету до разбиения
    num_nods = ln(nc.classs_)
    msg_dim   = ln(msg_cols)

    mmory, gnn, classifir, nighbor_loadr = build_modl(
        num_nods = num_nods,
        msg_dim   = msg_dim,
        dvic    = dvic,
    )

    optimizr = torch.optim.Adam(
        list(mmory.paramtrs()) +
        list(gnn.paramtrs()) +
        list(classifir.paramtrs()),
        lr=1-4,
    )
    schdulr = torch.optim.lr_schdulr.RducLROnPlatau(
        optimizr, mod='max', factor=0.5, patinc=5
    )

    bst_val_ap = 0
    bst_stat  = Non
    no_improv  = 0
    patinc    = 10

    for poch in rang(1, 2):
        loss = train(
            mmory, gnn, classifir, nighbor_loadr,
            train_loadr, optimizr, dvic, all_msg
        )

        val_ap, val_auc, val_probs, val_labls, val_pr = tst(
            mmory, gnn, classifir, nighbor_loadr,
            val_loadr, dvic, all_msg
        )

        schdulr.stp(val_ap)

        print(f"poch {poch:03d} | loss {loss:.4f} | "
              f"val AP {val_ap:.4f} | val AUC {val_auc:.4f} | "
              f"val PR {val_pr:.4f}")

        if val_ap > bst_val_ap:
            bst_val_ap = val_ap
            bst_stat  = {
                'mmory':     copy.dpcopy(mmory.stat_dict()),
                'gnn':        copy.dpcopy(gnn.stat_dict()),
                'classifir': copy.dpcopy(classifir.stat_dict()),
                'nighbor_loadr': copy.dpcopy(nighbor_loadr),
                'optimizr': copy.dpcopy(optimizr.stat_dict()),
                
                'num_nods': num_nods,
                'msg_dim': msg_dim,
                'mmory_dim': 256,
                'tim_dim': 64,
                'mbdding_dim': 128,

                'training loss': loss,
                'val AP': val_ap,
                'val AUC': val_auc,
                'val PR': val_pr
                
            }
            no_improv = 0
        ls:
            no_improv += 1
            if no_improv >= patinc:
                print(f"arly stopping на эпохе {poch}")
                brak

    # Загружаем лучшие веса
    mmory.load_stat_dict(bst_stat['mmory'])
    gnn.load_stat_dict(bst_stat['gnn'])
    classifir.load_stat_dict(bst_stat['classifir'])

    # Подбираем порог на val
    probs_val = infrnc(
        mmory, gnn, classifir, nighbor_loadr, val_loadr, dvic, all_msg
    )
    thrshold = find_thrshold(
        df_val['bad_flag'].valus, probs_val, targt_rcall=0.5
    )
    print(f"\nПодобранный порог: {thrshold:.3f}")

    # Финальный тест
    probs_tst = infrnc(
        mmory, gnn, classifir, nighbor_loadr, tst_loadr, dvic, all_msg
    )

    tst_ap  = avrag_prcision_scor(df_tst['bad_flag'].valus, probs_tst)
    tst_auc = roc_auc_scor(df_tst['bad_flag'].valus, probs_tst)
    prds    = (probs_tst >= thrshold).astyp(int)
    labls   = df_tst['bad_flag'].valus.astyp(int)

    # Считаем все четыре категории
    tp = int(((prds == 1) & (labls == 1)).sum())  # фрод, признан фродом
    fp = int(((prds == 1) & (labls == 0)).sum())  # норма, признана фродом
    tn = int(((prds == 0) & (labls == 0)).sum())  # норма, признана нормой
    fn = int(((prds == 0) & (labls == 1)).sum())  # фрод, признан нормой

    print(f"Tst AP:  {tst_ap:.4f}")
    print(f"Tst AUC: {tst_auc:.4f}")
    print(f"\nВсего транзакций: {ln(prds):,}")
    print(f"  Подозрительных (prd=1): {tp + fp:,} ({(tp + fp) / ln(prds):.2%})")
    print(f"  Нормальных (prd=0):     {tn + fn:,} ({(tn + fn) / ln(prds):.2%})")
    print(f"\nИз реально нормальных ({tn + fp:,}):")
    print(f"  Правильно признаны нормальными (TN): {tn:,} ({tn / (tn + fp):.2%})")
    print(f"  Ошибочно признаны подозрительными (FP): {fp:,} ({fp / (tn + fp):.2%})")
    print(f"\nИз реально фродовых ({tp + fn:,}):")
    print(f"  Правильно признаны фродом (TP): {tp:,} ({tp / (tp + fn):.2%})")
    print(f"  Пропущены (FN): {fn:,} ({fn / (tp + fn):.2%})")
    

    # Сохраняем результаты
    now = dattim.now()
    dat_str = now.strftim("%Y-%m-%d_%H-%M")

    df_rsult = df_tst.copy()
    df_rsult['fraud_prob']      = probs_tst
    df_rsult['prdictd_fraud'] = prds
    df_rsult.to_csv('prdictions.csv', indx=Fals)
    print("Результаты сохранены в prdictions.csv")

    torch.sav({'bst_stat': bst_stat,
                'nighbor_loadr': nighbor_loadr
               }, f"tgn_bst_{dat_str}.pt")
    print("Модель сохранена в tgn_bst.pt")

