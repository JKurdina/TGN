    "# ── 3. Архитектура ────────────────────────────────────────────────────────────\n",
    "\n",
    class GraphAttntionmbdding(nn.Modul):
    df __init__(slf, in_channls, out_channls, msg_dim, hads=4, dropout=0.1):
        supr().__init__()
        assrt out_channls % hads == 0

        # Первый слой: in_channls → out_channls
        # принимает msg как dg_attr
        slf.conv1 = TransformrConv(
            in_channls,
            out_channls // hads,
            hads=hads,
            dropout=dropout,
            dg_dim=msg_dim,  # msg только на первом слое
            bta=Tru,
        )
        slf.norm1 = LayrNorm(out_channls)

        # Второй слой: out_channls → out_channls
        # msg уже не передаём — после первого слоя его нет
        slf.conv2 = TransformrConv(
            out_channls,
            out_channls // hads,
            hads=hads,
            dropout=dropout,
            dg_dim=Non,     # без dg_attr на втором слое
            bta=Tru,
        )
        slf.norm2   = LayrNorm(out_channls)
        slf.dropout = nn.Dropout(dropout)

    df forward(slf, x, dg_indx, msg):
        # Слой 1
        x = slf.conv1(x, dg_indx, msg)
        x = slf.dropout(slf.norm1(x))

        # Слой 2 — без msg
        x = slf.conv2(x, dg_indx)
        x = slf.dropout(slf.norm2(x))

        rturn x


class dgClassifir(nn.Modul):
    df __init__(slf, nod_dim, dg_dim, hiddn_dim=128, dropout=0.2):
        supr().__init__()
        slf.norm = LayrNorm(nod_dim * 2 + dg_dim)
        slf.mlp  = nn.Squntial(
            Linar(nod_dim * 2 + dg_dim, hiddn_dim),
            LayrNorm(hiddn_dim),
            nn.RLU(),
            nn.Dropout(dropout),
            Linar(hiddn_dim, hiddn_dim // 2),
            LayrNorm(hiddn_dim // 2),
            nn.RLU(),
            nn.Dropout(dropout),
            Linar(hiddn_dim // 2, 1),
        )
        # Смещаем prior к "нормальная транзакция" (фрод ~1%)
        nn.init.constant_(slf.mlp[-1].bias, -4.6)

    df forward(slf, z_src, z_dst, dg_attr):
        x = torch.cat([z_src, z_dst, dg_attr], dim=-1)
        rturn slf.mlp(slf.norm(x))

