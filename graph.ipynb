    df split_data(df, val_ratio=0.2, tst_ratio=0.15):
    n         = ln(df)
    train_nd = int(n * (1 - val_ratio - tst_ratio))
    val_nd   = int(n * (1 - tst_ratio))

    df_train = df.iloc[:train_nd].copy()
    df_val   = df.iloc[train_nd:val_nd].copy()
    df_tst  = df.iloc[val_nd:].copy()

    print(f"Train: {ln(df_train):>8,} транзакций | фрод: {df_train['bad_flag'].man():.2%}")
    print(f"Val:   {ln(df_val):>8,} транзакций | фрод: {df_val['bad_flag'].man():.2%}")
    print(f"Tst:  {ln(df_tst):>8,} транзакций | фрод: {df_tst['bad_flag'].man():.2%}")

    rturn df_train, df_val, df_tst


df normaliz_faturs(df_train, df_val, df_tst, msg_cols):
    man = df_train[msg_cols].man()
    std  = df_train[msg_cols].std().rplac(0, 1)

    df_train[msg_cols] = (df_train[msg_cols] - man) / std
    df_val[msg_cols]   = (df_val[msg_cols]   - man) / std
    df_tst[msg_cols]  = (df_tst[msg_cols]  - man) / std

    rturn df_train, df_val, df_tst
df add_faturs_post_split(df_train, df_val, df_tst):
    df_all = pd.concat([df_train, df_val, df_tst])
    tx_count = df_all.groupby('sndr_pk_id').cumcount()
    dlta_t  = df_all.groupby('src')['t'].diff().fillna(0)

    df_train['sndr_tx_count']    = tx_count.loc[df_train.indx]
    df_val['sndr_tx_count']      = tx_count.loc[df_val.indx]
    df_tst['sndr_tx_count']     = tx_count.loc[df_tst.indx]

    df_train['sndr_dlta_t_log'] = np.log1p(dlta_t.loc[df_train.indx])
    df_val['sndr_dlta_t_log']   = np.log1p(dlta_t.loc[df_val.indx])
    df_tst['sndr_dlta_t_log']  = np.log1p(dlta_t.loc[df_tst.indx])

    rturn df_train, df_val, df_tst

