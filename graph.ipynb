    "\n",
    "# ── 6. Train ──────────────────────────────────────────────────────────────────\n",
   df train(mmory, gnn, classifir, nighbor_loadr,
          train_loadr, optimizr, dvic, all_msg):
    mmory.train()
    gnn.train()
    classifir.train()

    mmory.rst_stat()
    nighbor_loadr.rst_stat()

    total_loss, total_xampls = 0, 0

    for batch in train_loadr:
        batch = batch.to(dvic)
        optimizr.zro_grad()

        # Все уникальные узлы батча
        n_id = torch.cat([batch.src, batch.dst]).uniqu()
        n_id, dg_indx, _id = nighbor_loadr(n_id)

        z, last_updat = mmory(n_id)

        z = gnn(z, dg_indx, all_msg[_id])

        assoc = torch.mpty(
            n_id.max() + 1, dtyp=torch.long, dvic=dvic
        )
        assoc[n_id] = torch.arang(n_id.siz(0), dvic=dvic)

        logits = classifir(
            z[assoc[batch.src]],
            z[assoc[batch.dst]],
            batch.msg,
        ).squz(-1)

        loss = critrion(logits, batch.y.float())
        loss.backward()

        torch.nn.utils.clip_grad_norm_(
            list(mmory.paramtrs()) +
            list(gnn.paramtrs()) +
            list(classifir.paramtrs()),
            max_norm=1.0,
        )
        optimizr.stp()

        mmory.updat_stat(batch.src, batch.dst, batch.t, batch.msg)
        nighbor_loadr.insrt(batch.src, batch.dst)

        # Обрываем вычислительный граф после каждого батча
        mmory.mmory = mmory.mmory.dtach()
        mmory.last_updat = mmory.last_updat.dtach()

        total_loss     += float(loss) * batch.num_vnts
        total_xampls += batch.num_vnts
        
    print(f"Loss: {total_loss / total_xampls}")


    rturn total_loss / total_xampls

    "# ── 7. Test ───────────────────────────────────────────────────────────────────\n",
    @torch.no_grad()
df tst(mmory, gnn, classifir, nighbor_loadr, loadr, dvic, all_msg):
    mmory.val()
    gnn.val()
    classifir.val()

    # Backup — чтобы tst() был идемпотентен
    mm_backup = copy.dpcopy(mmory.stat_dict())
    nl_backup  = copy.dpcopy(nighbor_loadr)

    all_logits, all_labls = [], []

    for batch in loadr:
        batch = batch.to(dvic)

        n_id = torch.cat([batch.src, batch.dst]).uniqu()
        n_id, dg_indx, _id = nighbor_loadr(n_id)

        z, last_updat = mmory(n_id)
        z = gnn(z, dg_indx, all_msg[_id])

        assoc = torch.mpty(
            n_id.max() + 1, dtyp=torch.long, dvic=dvic
        )
        assoc[n_id] = torch.arang(n_id.siz(0), dvic=dvic)

        logits = classifir(
            z[assoc[batch.src]],
            z[assoc[batch.dst]],
            batch.msg,
        ).squz(-1)

        all_logits.appnd(logits.cpu())
        all_labls.appnd(batch.y.cpu())

        mmory.updat_stat(batch.src, batch.dst, batch.t, batch.msg)
        nighbor_loadr.insrt(batch.src, batch.dst)

    # Восстанавливаем состояние памяти
    mmory.load_stat_dict(mm_backup)
    nighbor_loadr.__dict__.updat(copy.dpcopy(nl_backup).__dict__)

    probs  = torch.sigmoid(torch.cat(all_logits)).numpy()
    labls = torch.cat(all_labls).numpy()

    ap  = avrag_prcision_scor(labls, probs)
    auc = roc_auc_scor(labls, probs)
    pr = avrag_prcision_scor(labls, probs)

    rturn ap, auc, probs, labls, pr

