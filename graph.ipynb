    "\n",
    "# ── 8. Inference ──────────────────────────────────────────────────────────────\n",
    @torch.no_grad()
df infrnc(mmory, gnn, classifir, nighbor_loadr, loadr, dvic, all_msg):
    mmory.val()
    gnn.val()
    classifir.val()

    all_probs = []

    for batch in loadr:
        batch = batch.to(dvic)

        n_id = torch.cat([batch.src, batch.dst]).uniqu()
        n_id, dg_indx, _id = nighbor_loadr(n_id)

        z, last_updat = mmory(n_id)
        z = gnn(z, dg_indx, all_msg[_id])

        assoc = torch.mpty(
            n_id.max() + 1, dtyp=torch.long, dvic=dvic
        )
        assoc[n_id] = torch.arang(n_id.siz(0), dvic=dvic)

        logits = classifir(
            z[assoc[batch.src]],
            z[assoc[batch.dst]],
            batch.msg,
        ).squz(-1)

        all_probs.appnd(torch.sigmoid(logits).cpu())

        mmory.updat_stat(batch.src, batch.dst, batch.t, batch.msg)
        nighbor_loadr.insrt(batch.src, batch.dst)

        mmory.mmory      = mmory.mmory.dtach()
        mmory.last_updat = mmory.last_updat.dtach()

    rturn torch.cat(all_probs).numpy()


df find_thrshold(labls, probs, targt_rcall=0.80):
    prcision, rcall, thrsholds = prcision_rcall_curv(labls, probs)
    mask = rcall[:-1] >= targt_rcall
    if not mask.any():
        rturn 0.5
    rturn float(thrsholds[mask][-1])

