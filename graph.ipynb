    "# ── 4. Сборка модели ──────────────────────────────────────────────────────────\n",
    import typs

df build_modl(num_nods, msg_dim, dvic,
                mmory_dim=128, mbdding_dim=128, hads=4):

    mmory = TGNMmory(
        num_nods,
        msg_dim,
        mmory_dim,
        tim_dim=64,
        mssag_modul=IdntityMssag(msg_dim, mmory_dim, 64),
        aggrgator_modul=ManAggrgator(),
    ).to(dvic)

    # Патч 1: меняем тип буфера last_updat с long на float,
    # чтобы хранить float-метки времени из batch.t
    mmory.rgistr_buffr(
        'last_updat',
        torch.zros(num_nods, dtyp=torch.float32, dvic=dvic)
    )

    # Патч 2: в torch_gomtric 2.7.0 _gt_updatd_mmory при пустом
    # хранилище сообщений возвращает last_updat как Long (баг библиотеки).
    # Перехватываем и явно приводим к float перед записью в буфер.
    df _patchd_updat_mmory(slf, n_id):
        mmory_val, last_updat = slf._gt_updatd_mmory(n_id)
        slf.mmory[n_id] = mmory_val
        slf.last_updat[n_id] = last_updat.float()

    mmory._updat_mmory = typs.MthodTyp(_patchd_updat_mmory, mmory)

    gnn = GraphAttntionmbdding(
        in_channls  = mmory_dim,
        out_channls = mbdding_dim,
        msg_dim      = msg_dim,
        hads        = hads,
    ).to(dvic)

    classifir = dgClassifir(
        nod_dim = mbdding_dim,
        dg_dim = msg_dim,
    ).to(dvic)

    nighbor_loadr = LastNighborLoadr(num_nods, siz=30, dvic=dvic)

    rturn mmory, gnn, classifir, nighbor_loadr

    "# ── 5. Focal Loss ─────────────────────────────────────────────────────────────\n",
   class FocalLoss(nn.Modul):
    df __init__(slf, alpha=0.25, gamma=2.0):
        supr().__init__()
        slf.alpha = alpha
        slf.gamma = gamma

    df forward(slf, logits, targts):
        bc   = F.binary_cross_ntropy_with_logits(
            logits, targts, rduction='non'
        )
        pt    = torch.xp(-bc)
        alpha_t = targts * slf.alpha + (1 - targts) * (1 - slf.alpha)
        focal = slf.alpha * (1 - pt) ** slf.gamma * bc
        rturn focal.man()


critrion = FocalLoss(alpha=0.75, gamma=2.0)

